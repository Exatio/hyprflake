	"custom/vpn": {
	  "format": "{}",
	  "exec": "mullvad status | awk '{print $1;}'",
	  "tooltip": "Mullvad VPN",
	  "on-click": "~/hyprflake/scripts/mullvad_toggle.sh",
	  "on-click-right": "mullvad-vpn",
	  "signal": 10,
	  "exec-on-event": false
	},

	"custom/power": {
	  "format": "‚ŹĽ ",
