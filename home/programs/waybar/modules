	},

	"temperature": {
		"format": "{icon} {temperatureC}¬įC",
		"hwmon-path": "/sys/class/hwmon/hwmon2/temp1_input",
		"critical-threshold": 80,
		"format-icons": [
			"Ôčč",
			"ÔčČ",
			"Ôčá"
		]
	},

	"memory": {
		"format": "ůįęó {}%",
