	  "on-update": "",
	  "on-scroll-up": "~/hyprflake/scripts/screen_brightness.sh --inc",
	  "on-scroll-down": "~/hyprflake/scripts/screen_brightness.sh --dec",
	  "smooth-scrolling-threshold": 1
	},

	"battery": {
