	  "align": 0,
	  "rotate": 0,
	  //"bat": "BAT1",
	  //"adapter": "ACAD",
	  "full-at": 100,
	  "design-capacity": false,
	  "states": {
	    "good": 95,
	    "warning": 30,
	    "critical": 15
	       },
